{
  "serial": {
    "port": "COM3",
    "baudrate": 9600,
    "bytesize": 8,
    "parity": "N",
    "stopbits": 1,
    "timeout_seconds": 1.2
  },
  "meter": {
    "read_command": "READ?",
    "line_terminator": "\\r\\n"
  },
  "calibration": {
    "point_count": 2,
    "standards": [4.00, 7.00],
    "enter_command": "CAL,START",
    "point_command_template": "CAL,POINT={point},VALUE={value}",
    "settle_seconds": 3.0,
    "step_timeout_seconds": 180.0,
    "exit_command": "CAL,END"
  },
  "polling": {
    "interval_seconds": 2.0
  },
  "ui": {
    "dark_mode": false
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8787
  },
  "mock_mode": false
}
